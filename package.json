{
  "name": "aviary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "packageManager": "npm@10.8.1",
  "scripts": {
    "local": "docker compose up --build",
    "local:down": "docker compose down -v",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "TEST_DATABASE_URL=postgres://aviary:aviary@localhost:5432/aviary vitest run",
    "test:stress": "RUN_STRESS=1 vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-prometheus": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/host-metrics": "^0.38.3",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "drizzle-orm": "^0.31.2",
    "fastify": "4.29.1",
    "pg": "^8.12.0",
    "yaml": "^2.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.22.7",
    "eslint": "^9.7.0",
    "prettier": "^3.2.5",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
